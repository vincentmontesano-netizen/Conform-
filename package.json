{
  "name": "conform-plus",
  "version": "0.1.0",
  "private": true,
  "description": "Plateforme SaaS de conformite reglementaire & prevention des risques",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "turbo dev --filter=@conform-plus/web",
    "dev:api": "turbo dev --filter=@conform-plus/api",
    "dev:rules": "cd services/rules-engine && uvicorn app.main:app --reload --port 8000"
  },
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.8.10"
  }
}
